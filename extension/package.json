{
  "name": "guruguru-codechan",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.5.4",
  "publisher": "hitsuki-ban",
  "license": "SEE LICENSE IN LICENSE",
  "type": "commonjs",
  "preview": true,
  "pricing": "Free",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#202124",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hitsuki-Ban/guruguru-codechan.git"
  },
  "bugs": {
    "url": "https://github.com/Hitsuki-Ban/guruguru-codechan/issues"
  },
  "homepage": "https://github.com/Hitsuki-Ban/guruguru-codechan#readme",
  "qna": false,
  "categories": [
    "Other"
  ],
  "keywords": [
    "guruguru",
    "codechan",
    "avatar",
    "companion",
    "pet",
    "webview"
  ],
  "engines": {
    "vscode": "^1.100.0",
    "node": ">=22.13.0"
  },
  "extensionKind": [
    "ui"
  ],
  "main": "./out/extension.js",
  "files": [
    "out",
    "dist",
    "media",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SUPPORT.md",
    "ASSET_LICENSE.md",
    "ASSET_PROVENANCE.json",
    "package.nls.json",
    "package.nls.ja.json",
    "package.nls.zh-cn.json",
    "package.json"
  ],
  "activationEvents": [
    "onCommand:guruguru-codechan.openCanvas",
    "onCommand:guruguru-codechan.switchCharacter",
    "onCommand:guruguru-codechan.toggleSettings",
    "onCommand:guruguru-codechan.setMouthLevel",
    "onView:guruguru-codechan.codechanView"
  ],
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "guruguru-codechan-container",
          "title": "%views.container.title%",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "guruguru-codechan-container": [
        {
          "type": "webview",
          "id": "guruguru-codechan.codechanView",
          "name": "%views.codechan.name%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "guruguru-codechan.switchCharacter",
          "when": "view == guruguru-codechan.codechanView",
          "group": "navigation@1"
        },
        {
          "command": "guruguru-codechan.toggleSettings",
          "when": "view == guruguru-codechan.codechanView",
          "group": "navigation@2"
        }
      ]
    },
    "commands": [
      {
        "command": "guruguru-codechan.openCanvas",
        "title": "%commands.openCanvas.title%",
        "category": "%commands.category%"
      },
      {
        "command": "guruguru-codechan.switchCharacter",
        "title": "%commands.switchCharacter.title%",
        "category": "%commands.category%",
        "icon": {
          "dark": "media/actions/dark/switch.svg",
          "light": "media/actions/light/switch.svg"
        }
      },
      {
        "command": "guruguru-codechan.toggleSettings",
        "title": "%commands.toggleSettings.title%",
        "category": "%commands.category%",
        "icon": "$(settings-gear)"
      }
    ],
    "walkthroughs": [
      {
        "id": "guruguru-codechan.gettingStarted",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "open-codechan-view",
            "title": "%walkthrough.open.title%",
            "description": "%walkthrough.open.description%",
            "media": {
              "markdown": "media/walkthrough/open-companion-view.md"
            },
            "completionEvents": [
              "onCommand:guruguru-codechan.openCanvas"
            ]
          },
          {
            "id": "adjust-settings-and-assets",
            "title": "%walkthrough.settings.title%",
            "description": "%walkthrough.settings.description%",
            "media": {
              "markdown": "media/walkthrough/settings-and-assets.md"
            },
            "completionEvents": [
              "onCommand:guruguru-codechan.toggleSettings"
            ]
          },
          {
            "id": "confirm-asset-rights",
            "title": "%walkthrough.rights.title%",
            "description": "%walkthrough.rights.description%",
            "media": {
              "markdown": "media/walkthrough/asset-rights.md"
            },
            "completionEvents": [
              "onLink:https://github.com/Hitsuki-Ban/guruguru-codechan/blob/main/extension/ASSET_LICENSE.md"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "clean": "node ./scripts/clean-output.mjs",
    "compile": "tsc -p ./tsconfig.json && node ./scripts/copy-runtime-vendor.mjs",
    "build:webview": "vite build",
    "build": "pnpm clean && pnpm compile && pnpm build:webview",
    "test": "vitest run",
    "package": "pnpm build && node ../scripts/package-extension.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.100.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/vsce": "^3.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@jsquash/png": "3.1.1",
    "@jsquash/resize": "2.1.1",
    "@jsquash/webp": "1.5.0",
    "wasm-feature-detect": "1.8.0"
  }
}
